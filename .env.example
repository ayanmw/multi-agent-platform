# Multi-Agent Platform — Environment Configuration Example
#
# Copy this file to `.env` and fill in your actual keys.
# Priority: system environment variables > .env > defaults in internal/config/config.go

# LLM provider
LLM_ENDPOINT=https://aicoding.dobest.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-v4-flash

# Optional: multi-model setup (JSON array)
# LLM_MODELS=[{"name":"deepseek-v4-flash","provider":"deepseek","endpoint":"https://aicoding.dobest.com/v1","api_key":"sk-xxx"}]
# LLM_PROVIDER_DEFAULT=deepseek-v4-flash

# Mock mode (default true for safe local testing)
LLM_USE_MOCK=true
# LLM_REAL_CASES=case-id-1,case-id-2

# Server
SERVER_PORT=8080
DB_PATH=data/app.db

# Auth (default off; set true to enforce API key on protected endpoints)
# REQUIRE_AUTH=true

# Logging
# LOG_LEVEL=info
# LOG_FILE=logs/server.log

# ---------------------------------------------------------------------------
# Tool-specific configuration
# ---------------------------------------------------------------------------

# Web search — provider-independent local search via Exa / Parallel MCP over HTTP.
# Without any keys/flags the tool returns a friendly "not configured" status.
# WEBSEARCH_PROVIDER=exa
# WEBSEARCH_ENABLE_EXA=true
# WEBSEARCH_ENABLE_PARALLEL=true
# WEBSEARCH_EXA_API_KEY=your-exa-key
# WEBSEARCH_PARALLEL_API_KEY=your-parallel-key

# MCP servers (JSON array of stdio transport configs)
# MCP_SERVERS=[{"name":"time","transport":"stdio","command":"node","args":["mcp/time.js"],"enabled":true}]

# Docker sandboxing for execute_program (default off)
# SANDBOX_ENABLE=true
# SANDBOX_IMAGE=python:3.11-slim

# ---------------------------------------------------------------------------
# Embedding provider — optional. Leave unset to use the zero-dependency local
# TF-IDF / hashed provider. Set EMBEDDING_PROVIDER=openai or cohere plus key.
# ---------------------------------------------------------------------------
# EMBEDDING_PROVIDER=openai
# EMBEDDING_ENDPOINT=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ---------------------------------------------------------------------------
# Observability (Phase 7-C)
# ---------------------------------------------------------------------------
# LOG_LEVEL=info
# AUDIT_BUFFER_LIMIT=10000
# TRACE_BUFFER_LIMIT=2000
